# Copy to .dev.vars for local wrangler pages dev usage.
# This file is for local development only. Production/preview secrets should be set in Cloudflare Pages.

# Comma-separated GitHub IDs that should be treated as admins after login.
ADMIN_GITHUB_IDS=

# GitHub OAuth app credentials.
# Local callback URL: http://localhost:8788/api/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Public site origin used to build OAuth callback URLs.
# Keep this aligned with the local port you use for `wrangler pages dev`.
SITE_URL=http://localhost:8788

# Session secret placeholder kept for config completeness.
# Generate a long random string; it is used to hash session tokens.
SESSION_SECRET=replace-with-a-long-random-secret

# OpenAI-compatible AI provider settings.
AI_BASE_URL=https://api.deepseek.com
AI_API_KEY=replace-with-your-ai-api-key
AI_MODEL_SUMMARY=deepseek-v4-flash
AI_MODEL_FORMAT=deepseek-v4-flash
AI_MODEL_POLISH=deepseek-v4-flash
AI_MODEL_TAGS=deepseek-v4-flash
AI_ALLOW_UNAUTHENTICATED_DEV=false
AI_DEBUG_LOG_RESPONSE=false

# Optional local-only shortcut login. Only works on localhost/127.0.0.1/::1.
DEV_AUTH_ENABLED=false
DEV_GITHUB_ID=
DEV_GITHUB_LOGIN=
DEV_GITHUB_AVATAR_URL=
